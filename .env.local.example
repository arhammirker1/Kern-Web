# ─── SUPABASE ────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
#
# SUPABASE_URL — your project URL (safe to expose, but keep it here anyway)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# SUPABASE_SERVICE_ROLE_KEY — NEVER expose this in frontend code.
# This key bypasses Row Level Security and can read/write everything.
# Only used in API routes (server-side). Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── SITE ────────────────────────────────────────────────────────────────────
# Your production URL — used for og:url, canonical links, sitemap
NEXT_PUBLIC_SITE_URL=https://kern.app

# ─── HOW TO USE ──────────────────────────────────────────────────────────────
# Local dev:  Copy this file to .env.local and fill in values
# Vercel:     Add each key in Project → Settings → Environment Variables
#
# RULE: Variables starting with NEXT_PUBLIC_ are exposed to the browser.
#       All other variables are server-only. Never put secret keys in
#       NEXT_PUBLIC_ variables.
